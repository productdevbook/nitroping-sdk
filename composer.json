{
  "name": "productdevbook/nitroping",
  "description": "Zero-dependency PHP SDK for nitroping push notifications. Send pushes, register devices, verify webhooks.",
  "type": "library",
  "license": "MIT",
  "keywords": ["push", "notifications", "apns", "fcm", "web-push", "sdk", "nitroping"],
  "homepage": "https://nitroping.dev",
  "readme": "php/README.md",
  "support": {
    "issues": "https://github.com/productdevbook/nitroping-sdk/issues",
    "source": "https://github.com/productdevbook/nitroping-sdk/tree/main/php"
  },
  "authors": [
    { "name": "productdevbook", "homepage": "https://github.com/productdevbook" }
  ],
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-hash": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.50"
  },
  "autoload": {
    "psr-4": { "Productdevbook\\Nitroping\\": "php/src/" }
  },
  "autoload-dev": {
    "psr-4": { "Productdevbook\\Nitroping\\Tests\\": "php/tests/" }
  },
  "scripts": {
    "test": "phpunit -c php/phpunit.xml.dist",
    "analyse": "phpstan analyse -c php/phpstan.neon",
    "fix": "php-cs-fixer fix --config=php/.php-cs-fixer.dist.php"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
